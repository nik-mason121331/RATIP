{
  "version": 2,
  "builds": [
    {
      "src": "backend/server/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "frontend/web/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server/app.py"
    },
    {
      "src": "/(.*\\..+)",
      "dest": "frontend/web/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/web/index.html"
    }
  ],
  "env": {
    "FLASK_ENV": "production"
  },
  "cleanUrls": true,
  "trailingSlash": false
}
